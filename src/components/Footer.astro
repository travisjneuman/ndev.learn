---
const year = new Date().getFullYear();
---

<footer
  style="background-color: var(--color-bg-subtle); border-top: 1px solid var(--color-border);"
>
  <div class="max-w-6xl mx-auto px-6 py-12">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-8">
      <div>
        <span
          class="text-lg font-bold tracking-tight"
          style="color: var(--color-text);"
        >
          neuman<span style="color: var(--color-accent-blue);">learn</span>
        </span>
        <p class="mt-2 text-sm" style="color: var(--color-text-muted);">
          Free, open-source programming education. Learn by building.
        </p>
      </div>

      <div>
        <h4
          class="text-sm font-semibold uppercase tracking-wider mb-3"
          style="color: var(--color-text-subtle);"
        >
          Platform
        </h4>
        <ul class="space-y-2">
          <li><a href="/#courses" class="text-sm" style="color: var(--color-text-muted);">Courses</a></li>
          <li><a href="/about" class="text-sm" style="color: var(--color-text-muted);">About</a></li>
          <li>
            <a
              href="https://github.com/travisjneuman/ndev.learn"
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm"
              style="color: var(--color-text-muted);"
            >
              Source Code
            </a>
          </li>
        </ul>
      </div>

      <div>
        <h4
          class="text-sm font-semibold uppercase tracking-wider mb-3"
          style="color: var(--color-text-subtle);"
        >
          Connect
        </h4>
        <ul class="space-y-2">
          <li>
            <a
              href="https://github.com/travisjneuman"
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm"
              style="color: var(--color-text-muted);"
            >
              GitHub
            </a>
          </li>
          <li>
            <a
              href="https://travisjneuman.com"
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm"
              style="color: var(--color-text-muted);"
            >
              Portfolio
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div
      class="mt-10 pt-6 text-center text-sm"
      style="border-top: 1px solid var(--color-border); color: var(--color-text-subtle);"
    >
      &copy; {year} Travis Neuman. MIT License.
    </div>
  </div>
</footer>
