---
const steps = [
  {
    number: '01',
    title: 'Choose a course',
    description: 'Browse our catalog and pick a language or technology. Each course has a clear progression from fundamentals to advanced.',
    color: 'var(--color-accent-blue)',
  },
  {
    number: '02',
    title: 'Build projects',
    description: 'Every concept is taught through hands-on projects. Write real code, run tests, and check solutions when you get stuck.',
    color: 'var(--color-accent-purple)',
  },
  {
    number: '03',
    title: 'Ship real skills',
    description: 'By the end, you have hundreds of projects under your belt and the skills to build production-grade software.',
    color: 'var(--color-accent-green)',
  },
];
---

<section class="py-20 px-6" style="background-color: var(--color-bg-subtle);">
  <div class="max-w-6xl mx-auto">
    <h2
      class="text-3xl sm:text-4xl font-bold text-center mb-4"
      style="color: var(--color-text);"
    >
      How It Works
    </h2>
    <p
      class="text-center mb-14 max-w-xl mx-auto"
      style="color: var(--color-text-muted);"
    >
      Three steps. No prerequisites. No cost.
    </p>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {steps.map((step) => (
        <div class="text-center">
          <div
            class="text-5xl font-bold mb-4"
            style={`color: ${step.color};`}
          >
            {step.number}
          </div>
          <h3
            class="text-xl font-semibold mb-2"
            style="color: var(--color-text);"
          >
            {step.title}
          </h3>
          <p class="text-sm leading-relaxed" style="color: var(--color-text-muted);">
            {step.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
