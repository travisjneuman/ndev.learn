---
import ThemeToggle from './ThemeToggle.tsx';
---

<header
  style="background-color: var(--color-bg); border-bottom: 1px solid var(--color-border);"
>
  <nav class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 no-underline">
      <span
        class="text-xl font-bold tracking-tight"
        style="color: var(--color-text);"
      >
        neuman<span style="color: var(--color-accent-blue);">learn</span>
      </span>
    </a>

    <div class="flex items-center gap-6">
      <a
        href="/#courses"
        class="text-sm font-medium hidden sm:block"
        style="color: var(--color-text-muted);"
      >
        Courses
      </a>
      <a
        href="/about"
        class="text-sm font-medium hidden sm:block"
        style="color: var(--color-text-muted);"
      >
        About
      </a>
      <a
        href="https://github.com/travisjneuman"
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm font-medium hidden sm:block"
        style="color: var(--color-text-muted);"
      >
        GitHub
      </a>
      <ThemeToggle client:load />
    </div>
  </nav>
</header>
