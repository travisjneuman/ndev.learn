---
import { getCollection } from 'astro:content';
import CourseCard from './CourseCard.astro';

const courses = (await getCollection('courses')).sort(
  (a, b) => a.data.order - b.data.order
);

const filters = [
  { key: 'all', label: 'All' },
  { key: 'programming', label: 'Programming' },
  { key: 'technical', label: 'Technical' },
  { key: 'creative', label: 'Creative' },
] as const;
---

<section id="courses" class="py-20 px-6">
  <div class="max-w-6xl mx-auto">
    <h2
      class="text-3xl sm:text-4xl font-bold text-center mb-4"
      style="color: var(--color-text);"
    >
      Available Courses
    </h2>
    <p
      class="text-center mb-10 max-w-xl mx-auto"
      style="color: var(--color-text-muted);"
    >
      Project-based curricula designed for hands-on learning. Start from zero, build real things.
    </p>

    <div class="flex justify-center gap-2 mb-10 flex-wrap" id="course-filters">
      {filters.map((f) => (
        <button
          class="filter-btn px-4 py-2 text-sm font-medium rounded-lg transition-colors"
          data-filter={f.key}
          style={f.key === 'all'
            ? 'background-color: var(--color-accent-blue); color: #fff;'
            : 'background-color: var(--color-bg-muted); color: var(--color-text-muted);'
          }
        >
          {f.label}
        </button>
      ))}
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="course-grid">
      {courses.map((course) => (
        <div data-category={course.data.category}>
          <CourseCard
            title={course.data.title}
            subtitle={course.data.subtitle}
            slug={course.id.replace(/\.md$/, '')}
            status={course.data.status}
            icon={course.data.icon}
            color={course.data.color}
            stats={course.data.stats}
          />
        </div>
      ))}
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    const buttons = document.querySelectorAll('#course-filters .filter-btn');
    const cards = document.querySelectorAll('#course-grid > [data-category]');

    buttons.forEach(function (btn) {
      btn.addEventListener('click', function () {
        var filter = btn.getAttribute('data-filter');

        buttons.forEach(function (b) {
          if (b === btn) {
            b.style.backgroundColor = 'var(--color-accent-blue)';
            b.style.color = '#fff';
          } else {
            b.style.backgroundColor = 'var(--color-bg-muted)';
            b.style.color = 'var(--color-text-muted)';
          }
        });

        cards.forEach(function (card) {
          if (filter === 'all' || card.getAttribute('data-category') === filter) {
            card.style.display = '';
          } else {
            card.style.display = 'none';
          }
        });
      });
    });
  })();
</script>
