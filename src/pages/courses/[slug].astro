---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const courses = await getCollection('courses');
  return courses.map((course) => ({
    params: { slug: course.id.replace(/\.md$/, '') },
    props: { course },
  }));
}

const { course } = Astro.props;
const { Content } = await course.render();
const { title, subtitle, status, url, github, icon, color, stats, tags } = course.data;
const isActive = status === 'active';
---

<Base title={title} description={subtitle}>
  <section class="py-24 px-6">
    <div class="max-w-4xl mx-auto">
      <!-- Back link -->
      <a
        href="/"
        class="inline-flex items-center gap-1 text-sm mb-8 no-underline"
        style="color: var(--color-text-muted);"
      >
        &larr; All Courses
      </a>

      <!-- Course header -->
      <div class="flex items-start gap-5 mb-8">
        <div
          class="w-16 h-16 rounded-xl flex items-center justify-center flex-shrink-0"
          style={`background-color: ${color}15;`}
        >
          <img src={icon} alt={`${title} logo`} class="w-10 h-10" />
        </div>
        <div>
          <div class="flex items-center gap-3 mb-1">
            <h1 class="text-3xl sm:text-4xl font-bold" style="color: var(--color-text);">
              {title}
            </h1>
            {isActive ? (
              <span
                class="text-xs font-medium px-2.5 py-1 rounded-full"
                style="background-color: var(--color-accent-green); color: #000;"
              >
                Active
              </span>
            ) : (
              <span
                class="text-xs font-medium px-2.5 py-1 rounded-full"
                style="background-color: var(--color-accent-yellow); color: #000;"
              >
                Coming Soon
              </span>
            )}
          </div>
          <p class="text-lg" style="color: var(--color-text-muted);">
            {subtitle}
          </p>
        </div>
      </div>

      <!-- Stats grid (active courses only) -->
      {isActive && (
        <div
          class="grid grid-cols-2 sm:grid-cols-4 gap-6 mb-10 p-6 rounded-xl"
          style="background-color: var(--color-bg-card); border: 1px solid var(--color-border);"
        >
          <div>
            <div class="text-3xl font-bold" style={`color: ${color};`}>{stats.projects}</div>
            <div class="text-sm" style="color: var(--color-text-subtle);">Projects</div>
          </div>
          <div>
            <div class="text-3xl font-bold" style={`color: ${color};`}>{stats.levels}</div>
            <div class="text-sm" style="color: var(--color-text-subtle);">Levels</div>
          </div>
          <div>
            <div class="text-3xl font-bold" style={`color: ${color};`}>{stats.modules}</div>
            <div class="text-sm" style="color: var(--color-text-subtle);">Modules</div>
          </div>
          {stats.conceptGuides && (
            <div>
              <div class="text-3xl font-bold" style={`color: ${color};`}>{stats.conceptGuides}</div>
              <div class="text-sm" style="color: var(--color-text-subtle);">Concept Guides</div>
            </div>
          )}
        </div>
      )}

      <!-- Tags -->
      <div class="flex flex-wrap gap-2 mb-10">
        {tags.map((tag) => (
          <span
            class="text-xs font-medium px-3 py-1 rounded-full"
            style="background-color: var(--color-bg-muted); color: var(--color-text-muted); border: 1px solid var(--color-border);"
          >
            {tag}
          </span>
        ))}
      </div>

      <!-- Course body (rendered markdown) -->
      <div
        class:list={['prose-custom space-y-4 resource-sections', { 'coming-soon-layout': !isActive }]}
        style="color: var(--color-text-muted);"
        data-course-color={color}
      >
        <Content />
      </div>

      <!-- CTAs -->
      <div
        id="course-ctas"
        class="mt-12 pt-8 flex flex-col sm:flex-row gap-4"
        style="border-top: 1px solid var(--color-border);"
      >
        {isActive && (
          <>
            <a
              href={url}
              class="inline-flex items-center justify-center px-8 py-3 text-base font-semibold rounded-lg no-underline transition-colors"
              style={`background-color: ${color}; color: #fff;`}
            >
              Start Learning
            </a>
            <a
              href={github}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center px-8 py-3 text-base font-semibold rounded-lg no-underline transition-colors"
              style="border: 1px solid var(--color-border); color: var(--color-text);"
            >
              View on GitHub
            </a>
          </>
        )}
      </div>
    </div>
  </section>
</Base>

<style>
  /* ─── Active course prose (simple, clean) ─── */
  .prose-custom :global(h2) {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-text);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .prose-custom :global(h3) {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-text);
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .prose-custom :global(p) {
    line-height: 1.75;
  }

  .prose-custom :global(strong) {
    color: var(--color-text);
  }

  .prose-custom :global(ul) {
    list-style: disc;
    padding-left: 1.5rem;
  }

  .prose-custom :global(li) {
    margin-bottom: 0.25rem;
  }

  /* ─── Shared resource sections — collapsible cards for both active and coming-soon ─── */

  /* Section headings that JS converts to collapsible card headers */
  .resource-sections :global(h2.resource-heading) {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-text);
    margin-top: 1.5rem;
    margin-bottom: 0;
    padding: 1rem 1.25rem;
    background-color: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem 0.75rem 0 0;
    cursor: pointer;
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.625rem;
  }

  /* Chevron indicator */
  .resource-sections :global(h2.resource-heading)::before {
    content: '▸';
    font-size: 0.75rem;
    color: var(--color-text-subtle);
    transition: transform 0.2s ease;
    flex-shrink: 0;
  }

  .resource-sections :global(h2.resource-heading.section-open)::before {
    transform: rotate(90deg);
  }

  /* Section emoji icons */
  .resource-sections :global(h2 .section-icon) {
    font-size: 1.125rem;
    flex-shrink: 0;
  }

  /* Resource count badge */
  .resource-sections :global(h2 .section-count) {
    margin-left: auto;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-text-subtle);
    background-color: var(--color-bg-muted);
    padding: 0.125rem 0.5rem;
    border-radius: 9999px;
  }

  /* Collapsible content body */
  .resource-sections :global(.section-content) {
    padding: 0.75rem 1.25rem 1.25rem;
    background-color: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-top: none;
    border-radius: 0 0 0.75rem 0.75rem;
    margin-bottom: 0.75rem;
  }

  .resource-sections :global(.section-content.collapsed) {
    display: none;
  }

  /* Reset list style inside resource sections */
  .resource-sections :global(.section-content ul) {
    list-style: none;
    padding-left: 0;
  }

  .resource-sections :global(.section-content li) {
    margin-bottom: 0;
  }

  /* Subcategory headings (h3) within sections */
  .resource-sections :global(.section-content h3) {
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-subtle);
    margin-top: 1.25rem;
    margin-bottom: 0.625rem;
    padding-bottom: 0.375rem;
    border-bottom: 1px solid var(--color-border-subtle);
  }

  .resource-sections :global(.section-content h3:first-child) {
    margin-top: 0.25rem;
  }

  /* Resource links as visual cards */
  .resource-sections :global(.section-content li) {
    padding: 0.625rem 0.75rem;
    border-radius: 0.5rem;
    transition: background-color 0.15s ease;
    border: 1px solid transparent;
    font-size: 0.875rem;
    line-height: 1.5;
    color: var(--color-text-muted);
  }

  .resource-sections :global(.section-content li:hover) {
    background-color: var(--color-bg-card-hover);
    border-color: var(--color-border-subtle);
  }

  .resource-sections :global(.section-content li a) {
    font-weight: 600;
    font-size: 0.9375rem;
    color: var(--color-accent-blue);
  }

  .resource-sections :global(.section-content li a:hover) {
    color: #60a5fa;
  }

  /* Roadmap section — numbered timeline */
  .resource-sections :global(.roadmap-section ol) {
    list-style: none;
    padding-left: 0;
    counter-reset: roadmap-step;
  }

  .resource-sections :global(.roadmap-section ol li) {
    counter-increment: roadmap-step;
    padding: 0.75rem 0.75rem 0.75rem 3rem;
    position: relative;
    border-left: 2px solid var(--color-border);
    margin-left: 0.875rem;
  }

  .resource-sections :global(.roadmap-section ol li)::before {
    content: counter(roadmap-step);
    position: absolute;
    left: -0.9375rem;
    top: 0.75rem;
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: 700;
    color: #fff;
    background-color: var(--color-accent-blue);
  }

  .resource-sections :global(.roadmap-section ol li:last-child) {
    border-left-color: transparent;
  }

  .resource-sections :global(.roadmap-section ol li strong) {
    display: block;
    font-size: 0.9375rem;
    margin-bottom: 0.125rem;
  }

  /* ─── Coming Soon intro-specific styles ─── */

  /* First h2 = "Coming Soon" header, styled prominently */
  .coming-soon-layout :global(h2:first-of-type) {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-accent-yellow);
    margin-top: 0;
    margin-bottom: 0.5rem;
    padding: 0;
    padding-bottom: 0.5rem;
    background: none;
    border: none;
    border-bottom: 1px solid var(--color-border);
    border-radius: 0;
    cursor: default;
    display: block;
  }

  .coming-soon-layout :global(h2:first-of-type)::before {
    content: none;
  }

  /* Intro paragraph (first p after first h2) */
  .coming-soon-layout :global(h2:first-of-type + p) {
    font-size: 1.0625rem;
    line-height: 1.8;
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
  }

  /* Second paragraph after intro */
  .coming-soon-layout :global(h2:first-of-type + p + p) {
    font-size: 0.9375rem;
    line-height: 1.75;
    color: var(--color-text-subtle);
    margin-bottom: 1.5rem;
  }

  /* ─── Active course resource divider ─── */
  .resource-sections :global(hr.resource-divider) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2.5rem 0 1.5rem;
  }

  /* Expand/collapse controls are styled inline via JS (Astro scoping doesn't reach dynamic elements) */
</style>

<script is:inline>
  (function () {
    var container = document.querySelector('.resource-sections');
    if (!container) return;

    var isComingSoon = container.classList.contains('coming-soon-layout');

    // Keywords that identify resource section headings (vs curriculum prose headings)
    var resourceKeywords = [
      'start here', 'learning roadmap', 'official', 'core documentation',
      'github awesome', 'curated collections', 'interactive', 'hands-on',
      'video', 'youtube', 'books', 'long-form', 'community', 'practice',
      'news', 'tools', 'environments', 'cheat sheet', 'certification',
    ];

    // Section heading icons based on content
    var sectionIcons = {
      'start here': '🗺️',
      'learning roadmap': '🗺️',
      'official': '📖',
      'core documentation': '📖',
      'github awesome': '⭐',
      'curated collections': '⭐',
      'interactive': '🧪',
      'hands-on': '🧪',
      'video': '🎬',
      'youtube': '🎬',
      'books': '📚',
      'long-form': '📚',
      'community': '👥',
      'practice': '👥',
      'news': '👥',
      'tools': '🔧',
      'environments': '🔧',
      'cheat sheet': '📋',
      'certification': '🎓',
    };

    function isResourceHeading(text) {
      var lower = text.toLowerCase();
      for (var i = 0; i < resourceKeywords.length; i++) {
        if (lower.indexOf(resourceKeywords[i]) !== -1) return true;
      }
      return false;
    }

    function getIcon(text) {
      var lower = text.toLowerCase();
      for (var key in sectionIcons) {
        if (lower.indexOf(key) !== -1) return sectionIcons[key];
      }
      return '📋';
    }

    // Get all h2 elements
    var headings = container.querySelectorAll('h2');
    var firstH2 = true;
    var sections = [];

    headings.forEach(function (h2) {
      // For coming-soon pages, skip the first h2 ("Coming Soon" intro header)
      if (isComingSoon && firstH2) {
        firstH2 = false;
        return;
      }
      firstH2 = false;

      // For active courses, only convert h2s that match resource keywords
      if (!isComingSoon && !isResourceHeading(h2.textContent)) {
        return; // Leave curriculum h2s (Course Overview, etc.) as plain prose
      }

      // Mark this h2 as a resource heading for CSS targeting
      h2.classList.add('resource-heading');

      // Create section content wrapper
      var contentDiv = document.createElement('div');
      contentDiv.className = 'section-content';

      // Collect all siblings until next h2
      var sibling = h2.nextElementSibling;
      var linkCount = 0;
      while (sibling && sibling.tagName !== 'H2') {
        var next = sibling.nextElementSibling;
        linkCount += sibling.querySelectorAll('li').length;
        contentDiv.appendChild(sibling);
        sibling = next;
      }

      // Insert content div after h2
      h2.insertAdjacentElement('afterend', contentDiv);

      // Add icon to heading
      var iconSpan = document.createElement('span');
      iconSpan.className = 'section-icon';
      iconSpan.textContent = getIcon(h2.textContent);
      h2.insertBefore(iconSpan, h2.firstChild);

      // Add count badge
      if (linkCount > 0) {
        var countSpan = document.createElement('span');
        countSpan.className = 'section-count';
        countSpan.textContent = linkCount + ' resources';
        h2.appendChild(countSpan);
      }

      // Mark roadmap section
      if (h2.textContent.toLowerCase().indexOf('roadmap') !== -1 ||
          h2.textContent.toLowerCase().indexOf('start here') !== -1) {
        contentDiv.classList.add('roadmap-section');
        // Start roadmap open
        h2.classList.add('section-open');
      } else {
        // Start other sections collapsed
        contentDiv.classList.add('collapsed');
      }

      // Click to toggle
      h2.addEventListener('click', function () {
        h2.classList.toggle('section-open');
        contentDiv.classList.toggle('collapsed');
      });

      sections.push({ h2: h2, content: contentDiv });
    });

    // Build expand/collapse controls (inserted into DOM below after layout is finalized)
    var controls = null;
    if (sections.length > 1) {
      controls = document.createElement('div');
      controls.style.cssText = 'display:flex;justify-content:flex-end;gap:0.75rem;margin-bottom:1rem;margin-top:1.25rem;';

      var btnBase = 'font-size:0.8125rem;font-weight:600;padding:0.5rem 1.25rem;border-radius:0.5rem;cursor:pointer;border:none;transition:all 0.2s ease;';

      var expandBtn = document.createElement('button');
      expandBtn.textContent = 'Expand All';
      expandBtn.style.cssText = btnBase + 'background:#3b82f6;color:#fff;';
      expandBtn.addEventListener('mouseenter', function () { expandBtn.style.background = '#60a5fa'; });
      expandBtn.addEventListener('mouseleave', function () { expandBtn.style.background = '#3b82f6'; });
      expandBtn.addEventListener('click', function () {
        sections.forEach(function (s) {
          s.h2.classList.add('section-open');
          s.content.classList.remove('collapsed');
        });
      });

      var collapseBtn = document.createElement('button');
      collapseBtn.textContent = 'Collapse All';
      collapseBtn.style.cssText = btnBase + 'background:#a855f7;color:#fff;';
      collapseBtn.addEventListener('mouseenter', function () { collapseBtn.style.background = '#c084fc'; });
      collapseBtn.addEventListener('mouseleave', function () { collapseBtn.style.background = '#a855f7'; });
      collapseBtn.addEventListener('click', function () {
        sections.forEach(function (s) {
          s.h2.classList.remove('section-open');
          s.content.classList.add('collapsed');
        });
      });

      controls.appendChild(expandBtn);
      controls.appendChild(collapseBtn);
    }

    // For active courses: move CTAs above resource sections, add resources header, then controls
    if (!isComingSoon && sections.length > 0) {
      var ctaBlock = document.getElementById('course-ctas');
      var firstResourceH2 = sections[0].h2;

      if (ctaBlock && firstResourceH2) {
        // Remove bottom-of-page border styling, add spacing instead
        ctaBlock.style.borderTop = 'none';
        ctaBlock.style.paddingTop = '0';
        ctaBlock.style.marginTop = '2.5rem';
        ctaBlock.style.marginBottom = '0';

        // Move CTA block before the first resource heading
        firstResourceH2.parentNode.insertBefore(ctaBlock, firstResourceH2);

        // Inject a "More Resources" section header
        var resHeader = document.createElement('div');
        resHeader.style.cssText = 'margin-top:3rem;margin-bottom:0.25rem;padding-top:2rem;border-top:1px solid var(--color-border);';

        var resTitle = document.createElement('h2');
        resTitle.textContent = 'More Resources';
        resTitle.style.cssText = 'font-size:1.5rem;font-weight:700;color:var(--color-text);margin:0 0 0.5rem 0;';

        var resDesc = document.createElement('p');
        resDesc.textContent = 'Curated links to the best free learning materials across the internet.';
        resDesc.style.cssText = 'font-size:0.9375rem;color:var(--color-text-subtle);margin:0;line-height:1.6;';

        resHeader.appendChild(resTitle);
        resHeader.appendChild(resDesc);
        firstResourceH2.parentNode.insertBefore(resHeader, firstResourceH2);

        // Insert expand/collapse controls after the header, before resource sections
        if (controls) {
          firstResourceH2.parentNode.insertBefore(controls, firstResourceH2);
        }
      }
    } else if (controls && sections[0]) {
      // Coming-soon pages: controls go directly before first resource section
      sections[0].h2.parentNode.insertBefore(controls, sections[0].h2);
    }

    // Open all external links in new tab (only within resource sections)
    container.querySelectorAll('.section-content a[href^="http"]').forEach(function (a) {
      a.setAttribute('target', '_blank');
      a.setAttribute('rel', 'noopener noreferrer');
    });
  })();
</script>
